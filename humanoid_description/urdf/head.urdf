<?xml version="1.0"?>
<robot name="capstone_head">

  <link name="head_link">
    <visual>
      <geometry><box size="0.1 0.15 0.1"/></geometry>
      <material name="grey"><color rgba="0.6 0.6 0.6 1.0"/></material>
    </visual>
  </link>

  <joint name="head_to_camera" type="fixed">
    <parent link="head_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> 
  </joint>

  <link name="camera_link"/>

  <joint name="head_to_laser" type="fixed">
    <parent link="head_link"/>
    <child link="laser"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/> 
  </joint>

  <link name="laser"/>

</robot>
